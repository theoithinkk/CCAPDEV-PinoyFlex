<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="nav">
    <div class="container">
      <a href="/">PinoyFlex</a>
      <a href="/posts">Posts</a>
      <a href="/users">Users</a>
      <% if (currentUser) { %><a href="/posts/new">Create Post</a><a href="/users/me">My Profile</a><% } %>
      <span class="spacer"></span>
      <% if (currentUser) { %>
        <span>@<%= currentUser.username %></span>
        <form method="POST" action="/auth/logout"><button type="submit">Logout</button></form>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </div>
  </header>

  <main class="container">
    <div class="card">
      <h1>All Posts</h1>
      <div class="inline">
        <% if (currentUser) { %>
          <a class="btn" href="/posts/new">Create New Post</a>
        <% } else { %>
          <a class="btn" href="/auth/login">Login to Post</a>
        <% } %>
      </div>
    </div>

    <div class="list">
      <% posts.forEach(function(post) { %>
        <article class="card">
          <h2 class="post-title"><a href="/posts/<%= post._id %>"><%= post.title %></a></h2>
          <div class="muted">Tag: <%= post.tag %> | Votes: <%= post.votes %> | Comments: <%= post.commentCount %></div>
          <div class="muted">By <%= post.author?.username || "unknown" %> on <%= new Date(post.createdAt).toLocaleString() %></div>
        </article>
      <% }) %>
    </div>
  </main>
</body>
</html>
