<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="nav">
    <div class="container">
      <a href="/">PinoyFlex</a>
      <a href="/posts">Posts</a>
      <a href="/users">Users</a>
      <a href="/posts/new">Create Post</a>
      <a href="/users/me">My Profile</a>
      <span class="spacer"></span>
      <span>@<%= currentUser.username %></span>
      <form method="POST" action="/auth/logout"><button type="submit">Logout</button></form>
    </div>
  </header>

  <main class="container">
    <div class="card">
      <h1>My Profile</h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <p><strong>Username:</strong> @<%= user.username %></p>
      <p><strong>Avatar URL:</strong> <%= user.avatar %></p>
      <p><strong>Bio:</strong> <%= user.bio || "No bio yet." %></p>

      <h2>Edit Profile</h2>
      <form method="POST" action="/users/me">
        <label>Avatar URL
          <input name="avatar" value="<%= user.avatar %>" />
        </label>
        <label>Bio
          <textarea name="bio" rows="3"><%= user.bio %></textarea>
        </label>
        <button class="btn" type="submit">Save Profile</button>
      </form>
    </div>

    <div class="card">
      <h2>My Posts</h2>
      <div class="list">
        <% posts.forEach(function(post) { %>
          <div>
            <a href="/posts/<%= post._id %>"><%= post.title %></a>
            <div class="muted"><%= new Date(post.createdAt).toLocaleString() %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</body>
</html>
